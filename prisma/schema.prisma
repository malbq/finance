generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma-app/client"
  previewFeatures = ["views"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BANK
  CREDIT
}

enum AccountSubtype {
  CHECKING_ACCOUNT
  CREDIT_CARD
}

enum InvestmentType {
  COE
  EQUITY
  ETF
  FIXED_INCOME
  MUTUAL_FUND
  SECURITY
  OTHER
}

enum InvestmentSubtype {
  STRUCTURED_NOTE
  STOCK
  ETF
  REAL_ESTATE_FUND
  BDR
  DERIVATIVES
  OPTION
  TREASURY
  LCI
  LCA
  LF
  CDB
  CRI
  CRA
  CORPORATE_DEBT
  LC
  DEBENTURES
  INVESTMENT_FUND
  MULTIMARKET_FUND
  FIXED_INCOME_FUND
  STOCK_FUND
  ETF_FUND
  OFFSHORE_FUND
  FIP_FUND
  EXCHANGE_FUND
  RETIREMENT
  OTHER
}

enum InvestmentStatus {
  ACTIVE
  PENDING
  TOTAL_WITHDRAWAL
}

enum InvestmentTransactionType {
  BUY
  SELL
  TAX
  TRANSFER
  INTEREST
  AMORTIZATION
}

enum MovementType {
  CREDIT
  DEBIT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  POSTED
  PENDING
}

model Account {
  id            String          @id
  itemId        String
  number        String?
  type          AccountType
  subtype       AccountSubtype?
  name          String
  balance       Decimal
  currencyCode  String          @default("BRL")
  marketingName String?
  taxNumber     String?
  owner         String?
  createdAt     DateTime
  updatedAt     DateTime
  transactions  Transaction[]
  bankData      BankData?
  creditData    CreditData?
}

model BankData {
  id                           String   @id @default(uuid())
  accountId                    String   @unique
  transferNumber               String?
  closingBalance               Decimal?
  automaticallyInvestedBalance Decimal?
  overdraftContractedLimit     Decimal?
  overdraftUsedLimit           Decimal?
  unarrangedOverdraftAmount    Decimal?
  account                      Account  @relation(fields: [accountId], references: [id])
}

model CreditData {
  id                     String    @id @default(uuid())
  accountId              String    @unique
  level                  String
  brand                  String
  balanceCloseDate       DateTime?
  balanceDueDate         DateTime
  availableCreditLimit   Decimal
  balanceForeignCurrency Decimal?
  minimumPayment         Decimal?
  creditLimit            Decimal
  isLimitFlexible        Boolean?
  holderType             String?
  status                 String?
  account                Account   @relation(fields: [accountId], references: [id])
}

model Transaction {
  id                      String              @id
  accountId               String
  description             String
  descriptionRaw          String?
  currencyCode            String              @default("BRL")
  amount                  Decimal
  amountInAccountCurrency Decimal?
  date                    DateTime
  category                String?
  categoryId              String?
  balance                 Decimal?
  providerCode            String?
  status                  TransactionStatus
  type                    TransactionType
  operationType           String?
  providerId              String?
  createdAt               DateTime
  updatedAt               DateTime
  account                 Account             @relation(fields: [accountId], references: [id])
  paymentData             PaymentData?
  creditCardMetadata      CreditCardMetadata?
  acquirerData            AcquirerData?
  merchant                Merchant?
}

model PaymentData {
  id                  String              @id @default(uuid())
  transactionId       String              @unique
  paymentMethod       String?
  reason              String?
  receiverReferenceId String?
  referenceNumber     String?
  boletoMetadata      String?
  transaction         Transaction         @relation(fields: [transactionId], references: [id])
  payer               PaymentParticipant? @relation("PayerRelation")
  receiver            PaymentParticipant? @relation("ReceiverRelation")
}

model PaymentParticipant {
  id                    String       @id @default(uuid())
  accountNumber         String?
  branchNumber          String?
  documentType          String?
  documentValue         String?
  name                  String?
  routingNumber         String?
  routingNumberISPB     String?
  payerPaymentData      PaymentData? @relation("PayerRelation", fields: [payerPaymentDataId], references: [id])
  payerPaymentDataId    String?      @unique
  receiverPaymentData   PaymentData? @relation("ReceiverRelation", fields: [receiverPaymentDataId], references: [id])
  receiverPaymentDataId String?      @unique
}

model CreditCardMetadata {
  id            String      @id @default(uuid())
  transactionId String      @unique
  data          String?
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model AcquirerData {
  id            String      @id @default(uuid())
  transactionId String      @unique
  data          String?
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Merchant {
  id            String      @id @default(uuid())
  transactionId String      @unique
  cnae          String?
  cnpj          String?
  name          String?
  category      String?
  businessName  String?
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Investment {
  id                     String                  @id
  itemId                 String
  type                   InvestmentType
  subtype                InvestmentSubtype?
  number                 String?
  balance                Decimal
  name                   String
  lastMonthRate          Float?
  lastTwelveMonthsRate   Float?
  annualRate             Float?
  currencyCode           String                  @default("BRL")
  code                   String?
  isin                   String?
  value                  Float?
  quantity               Float?
  amount                 Float?
  taxes                  Float?
  taxes2                 Float?
  date                   DateTime
  owner                  String?
  amountProfit           Float?
  amountWithdrawal       Float?
  amountOriginal         Float?
  dueDate                DateTime?
  issuer                 String?
  issuerCNPJ             String?
  issueDate              DateTime?
  rate                   Float?
  rateType               String?
  fixedAnnualRate        Float?
  status                 InvestmentStatus?
  institution            String?
  metadata               String?
  createdAt              DateTime
  updatedAt              DateTime
  investmentTransactions InvestmentTransaction[]

  @@unique([itemId, id])
}

model InvestmentTransaction {
  id              String                    @id
  investmentId    String
  type            InvestmentTransactionType
  movementType    MovementType?
  quantity        Float?
  value           Float?
  amount          Float?
  netAmount       Float?
  description     String?
  agreedRate      Float?
  date            DateTime
  tradeDate       DateTime?
  brokerageNumber String?
  expenses        String?
  investment      Investment                @relation(fields: [investmentId], references: [id])
}

model Category {
  id                    String     @id
  description           String
  descriptionTranslated String
  parentId              String?
  parentDescription     String?
  parent                Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children              Category[] @relation("CategoryHierarchy")
}

view MovingAverageProjections {
  category String   @unique
  value    Decimal?
}
