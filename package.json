{
  "name": "finance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run watch-routes & NODE_ENV=development bun run server.ts",
    "start": "bun run generate-routes && NODE_ENV=production bun run server.ts",
    "typecheck": "bunx tsc --noEmit",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "generate:categories": "bun scripts/generate-categories.ts",
    "service:setup": "sudo ./systemd/setup.sh",
    "service:start": "sudo systemctl start finance",
    "service:stop": "sudo systemctl stop finance",
    "service:status": "sudo systemctl status finance | cat",
    "service:log": "sudo journalctl -u finance -n 200 -f"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@tanstack/query-db-collection": "^1.0.22",
    "@tanstack/react-db": "^0.1.69",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.158.0",
    "drizzle-orm": "^1.0.0-beta.9-e89174b",
    "openai": "^6.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.158.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^12.6.2",
    "bun-plugin-tailwind": "^0.1.2",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
