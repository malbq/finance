{
  "name": "finance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "typecheck": "react-router typegen && tsc",
    "build": "react-router build",
    "start": "bun server.ts",
    "prisma:generate": "bunx prisma generate && bun run generate:categories",
    "generate:categories": "bun scripts/generate-categories.ts",
    "db:views": "sqlite3 db/finance.db < prisma/migrations/01_results_moving_average_view.sql",
    "service:setup": "sudo ./systemd/setup.sh",
    "service:start": "sudo systemctl start finance",
    "service:stop": "sudo systemctl stop finance",
    "service:status": "sudo systemctl status finance | cat",
    "service:log": "sudo journalctl -u finance -n 200 -f"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@prisma/client": "^6.14.0",
    "@react-router/node": "^7.8.1",
    "isbot": "^5.1.30",
    "prisma": "^6.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.8.1",
    "recharts": "^3.1.2"
  },
  "devDependencies": {
    "@react-router/dev": "^7.8.1",
    "@tailwindcss/vite": "^4.1.12",
    "@types/bun": "^1.2.20",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
